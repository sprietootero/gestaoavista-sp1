# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA suba o .env para o GitHub (já está no .gitignore)

# Credenciais de login no w1nner
CONTA1_EMAIL=seu_email@w1consultoria.com.br
CONTA1_SENHA=sua_senha

# Opcional: segunda conta (caso precise de dois logins para extrair todos os dados)
# CONTA2_EMAIL=outro_email@w1consultoria.com.br
# CONTA2_SENHA=outra_senha

# Nome do escritório exatamente como aparece no filtro do w1nner
# Exemplos: "W1 SP1", "W1 São Paulo 1", "Office SP1" — verifique no painel
NOME_ESCRITORIO=W1 SP1
